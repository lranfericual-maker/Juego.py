import random

def show_welcome():
    print("¡Bienvenido al juego Adivina el Número!")
    print("Tienes que adivinar un número entre 1 y 20.")

def get_user_guess():
    """Solicita un número al usuario y valida la entrada."""
    while True:
        try:
            guess = int(input("Ingresa tu intento: "))
            return guess
        except ValueError:
            print("Por favor, ingresa un número válido.")

def play_game():
    secret_number = random.randint(1, 20)
    attempts = 0

    while True:
        user_guess = get_user_guess()
        attempts += 1

        if user_guess < secret_number:
            print("Muy bajo")
        elif user_guess > secret_number:
            print("Muy alto")
        else:
            print("¡Correcto!")
            print(f"Número de intentos: {attempts}")
            break

def main():
    show_welcome()
    while True:
        play_game()
        again = input("¿Quieres jugar otra vez? (s/n): ").lower()
        if again != 's':
            print("¡Gracias por jugar! Hasta la próxima.")
            break

